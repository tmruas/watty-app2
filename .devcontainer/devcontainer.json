{
  "name": "Watty (Next.js)",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": ["watty_app.py", "web/app/page.tsx"]
    },
    "vscode": {
      "settings": {},
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  },
  "updateContentCommand": "cd web && npm install && echo '✅ web dependencies installed'",
  "postAttachCommand": "cd web && npm run dev -- --hostname 0.0.0.0 --port 3000",
  "portsAttributes": {
    "3000": {
      "label": "Watty Next.js",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [3000]
}
